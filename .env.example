# LPII AutoGrader — Environment Configuration
#
# Copy this file to .env and fill in the values before first run:
#   cp .env.example .env
#
# Then start the system:
#   ./start.sh
#
# Create the professor account (first time only):
#   python scripts/create_admin.py --name "Prof. Bidu" --email bidu@lavid.ufpb.br --password <senha>

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: Change this before any real use. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
PORT=8000

# Public URL (used in emails / links — set to your server's address)
SITE_URL=http://localhost:8000

# ── Storage ───────────────────────────────────────────────────────────────────
# Defaults to ./storage/ (relative to project root)
# STORAGE_DIR=/data/autograder

# ── Sandbox ───────────────────────────────────────────────────────────────────
# "unshare" = Linux production (recommended)
# "none"    = macOS or dev environments (no isolation)
SANDBOX_MODE=unshare

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
# Set LLM_ENABLED=true to activate qualitative code analysis
LLM_ENABLED=false
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5-coder:14b

# ── GitHub ────────────────────────────────────────────────────────────────────
# Optional. Without token, GitHub API rate limit is 60 req/h (usually enough).
# Create at: https://github.com/settings/tokens (read:public_repo scope)
GITHUB_TOKEN=
